# =============================================================================
# Helix AI Virtual Receptionist — Configuration
# Copy this file to .env and edit the values marked CHANGE_ME
# =============================================================================

# ── Asterisk ARI ──────────────────────────────────────────────────────────────
ASTERISK_HOST=localhost
ASTERISK_ARI_PORT=8088
ASTERISK_ARI_USER=pbx-agent
ASTERISK_ARI_PASSWORD=CHANGE_ME_ARI_PASSWORD    # must match ari.conf
ASTERISK_APP_NAME=pbx-agent

# ── RTP ───────────────────────────────────────────────────────────────────────
# Bind address for agent RTP sockets.
# Use 0.0.0.0 in Docker bridge mode, 127.0.0.1 for native/host-network.
AGENT_RTP_HOST=127.0.0.1
AGENT_RTP_PORT_START=20000
AGENT_RTP_PORT_END=20100
# Advertise address sent to Asterisk (needed in Docker bridge mode).
# Set to the agent container's service name, e.g. "agent". Leave blank otherwise.
AGENT_RTP_ADVERTISE_HOST=

# ── Silero VAD ────────────────────────────────────────────────────────────────
# Speech probability threshold (0.0–1.0).
# 0.5 works for most environments. Raise to 0.6–0.7 in noisy rooms.
VAD_THRESHOLD=0.5
# Milliseconds of silence after speech before utterance is considered complete.
VAD_MIN_SILENCE_MS=600
# Padding (ms) added to detected speech start/end to capture soft onsets.
VAD_SPEECH_PAD_MS=100

# ── Whisper STT ───────────────────────────────────────────────────────────────
# Fallback model (used when AUTO_DETECT_LANGUAGE=false).
WHISPER_MODEL=base.en
# Multilingual model (used when AUTO_DETECT_LANGUAGE=true).
# MUST NOT end in .en — needs multilingual support for Spanish detection.
WHISPER_MODEL_MULTILINGUAL=base
WHISPER_DEVICE=cuda           # cuda (RTX GPU) | cpu
WHISPER_COMPUTE_TYPE=float16  # float16 for GPU, int8 for CPU

# ── Ollama LLM ────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434    # Use http://ollama:11434 in Docker Compose
OLLAMA_MODEL=llama3.1:8b             # Intent detection, conversation, translation
OLLAMA_TIMEOUT=30

# ── Kokoro TTS ─────────────────────────────────────────────────────────────────
# Voice name for each Kokoro-supported language. Leave blank to use the built-in default.
# Full voice list: https://huggingface.co/hexgrad/Kokoro-82M/blob/main/VOICES.md
# Kokoro natively supports: EN, ES, FR, IT
# DE, RO, and HE are handled automatically by espeak-ng (no Kokoro voice available)
KOKORO_VOICE_EN=af_heart    # American English female (warm, natural)
KOKORO_VOICE_ES=ef_dora     # Spanish female
KOKORO_VOICE_FR=ff_siwis    # French female
KOKORO_VOICE_IT=if_sara     # Italian female

# ── Multilingual / Translation ────────────────────────────────────────────────
SUPPORTED_LANGUAGES=en,es,fr,it,de,ro,he
AUTO_DETECT_LANGUAGE=true

# ── Google Calendar ───────────────────────────────────────────────────────────
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json
GOOGLE_CALENDAR_ID=primary
APPOINTMENT_SLOT_MINUTES=30
AVAILABILITY_LOOKAHEAD_DAYS=7

# ── Business identity ─────────────────────────────────────────────────────────
AGENT_NAME=Alex                         # CHANGE_ME — receptionist name in greetings
BUSINESS_NAME=My Business               # CHANGE_ME — spoken in every greeting
BUSINESS_HOURS_START=9                  # 9 AM local time
BUSINESS_HOURS_END=17                   # 5 PM local time
BUSINESS_TIMEZONE=America/Chicago       # CHANGE_ME — tz database string

# ── After-hours & holiday behavior ────────────────────────────────────────────
# Comma-separated ISO dates for hard-closed holidays (no staff, all modes apply).
# Example: HOLIDAY_DATES=2026-12-25,2026-12-26,2027-01-01
HOLIDAY_DATES=

# What to do when a caller reaches us outside business hours or on a holiday:
#   callback   → tell caller to call back during hours (default, simplest)
#   voicemail  → record a voicemail (requires VOICEMAIL_ENABLED=true)
#   schedule   → let caller book a callback via Google Calendar (AI flow continues)
#   emergency  → immediately transfer to EMERGENCY_EXTENSION
AFTER_HOURS_MODE=callback

# Extension reached when AFTER_HOURS_MODE=emergency, or as the operator fallback
OPERATOR_EXTENSION=1001
EMERGENCY_EXTENSION=1001

# ── Retry / fallback behavior ─────────────────────────────────────────────────
# How many consecutive silence/unknown events before offering operator transfer.
MAX_RETRIES=3
# Seconds of silence (no RTP audio) before counting as a missed turn.
SILENCE_TIMEOUT_SEC=8

# ── DTMF fallback menu ────────────────────────────────────────────────────────
# Set true to announce a keypress menu alongside the spoken greeting.
# Callers can always speak naturally — DTMF is a secondary escape hatch.
DTMF_ENABLED=false
# JSON map of digit → extension. Customize to match your extensions.
DTMF_MAP={"1":"1002","2":"1003","0":"1001"}

# ── VIP / known-caller routing ────────────────────────────────────────────────
# Comma-separated caller IDs that bypass the AI and go directly to OPERATOR_EXTENSION.
# Useful for owner's cell, key clients, etc.
# Example: VIP_CALLERS=+12125550100,+13125550199
VIP_CALLERS=

# ── Extension Routing ─────────────────────────────────────────────────────────
# JSON map of intent keywords → extension numbers.
# Also editable live via the dashboard Routing page.
ROUTING_RULES={"sales":"1002","billing":"1002","support":"1003","technical":"1003","operator":"1001","default":"1001"}

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=127.0.0.1         # loopback — nginx proxies externally. Change to 0.0.0.0 ONLY if not using nginx.
API_PORT=8000
# Allowed CORS origins for the FastAPI agent. Comma-separated.
# In production this should be your nginx host, not *
API_CORS_ORIGINS=http://127.0.0.1,http://localhost

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/pbx_assistant.db

# ── Optional feature flags ────────────────────────────────────────────────────
# All features below are disabled by default and degrade gracefully when off.

# Voicemail recording (used with AFTER_HOURS_MODE=voicemail or no-answer fallback).
# Requires a writable directory. Audio is saved as .wav.
VOICEMAIL_ENABLED=false
VOICEMAIL_DIR=/var/spool/helix/voicemail
# Set false to skip Whisper transcription of voicemail (saves CPU)
VOICEMAIL_TRANSCRIBE=true

# LLM-generated post-call summary stored in call_logs.summary.
# Adds 1-2 seconds at call end. Costs one Ollama inference per call.
CALL_SUMMARY_ENABLED=false

# FAQ / business-info lookup from a local plain-text file.
# Each non-blank line is one FAQ entry. Keyword-matched against caller utterances.
# Matching chunks are injected into the LLM context window.
FAQ_ENABLED=false
FAQ_FILE=faq.txt

# ── CRM / Vtiger ─────────────────────────────────────────────────────────────
VTIGER_ENABLED=false
VTIGER_BASE_URL=http://127.0.0.1:8188
VTIGER_USERNAME=admin
VTIGER_ACCESS_KEY=
VTIGER_DEFAULT_MODULE=Contacts
