# =============================================================================
# Helix AI Virtual Receptionist — Windows / Docker Desktop configuration
# Pre-configured for bridge networking + CPU Whisper.
# The deploy-windows.ps1 script patches ASTERISK pjsip.conf automatically.
# =============================================================================

# ── Asterisk ARI ──────────────────────────────────────────────────────────────
# "asterisk" resolves to the Asterisk container via Docker DNS
ASTERISK_HOST=asterisk
ASTERISK_ARI_PORT=8088
ASTERISK_ARI_USER=pbx-agent
ASTERISK_ARI_PASSWORD=CHANGE_ME_ARI_PASSWORD    # must match ari.conf
ASTERISK_APP_NAME=pbx-agent

# ── RTP ───────────────────────────────────────────────────────────────────────
# 0.0.0.0 so the container socket accepts RTP from the Asterisk container
AGENT_RTP_HOST=0.0.0.0
AGENT_RTP_PORT_START=20000
AGENT_RTP_PORT_END=20100
# Docker service name — Asterisk uses this to route RTP back to the agent
AGENT_RTP_ADVERTISE_HOST=agent

# ── Silero VAD ────────────────────────────────────────────────────────────────
VAD_THRESHOLD=0.5
VAD_MIN_SILENCE_MS=600
VAD_SPEECH_PAD_MS=100

# ── Whisper STT ───────────────────────────────────────────────────────────────
# CPU mode for Windows testing — int8 is fastest on CPU
# base model is multilingual so Spanish detection works
WHISPER_MODEL=base.en
WHISPER_MODEL_MULTILINGUAL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ── Ollama LLM ────────────────────────────────────────────────────────────────
# "ollama" resolves to the Ollama container via Docker DNS
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b

# ── Piper TTS ─────────────────────────────────────────────────────────────────
PIPER_MODEL=en_US-lessac-medium
PIPER_MODEL_ES=es_MX-claude-high
PIPER_MODEL_PATH=/opt/piper/models

# ── Bilingual / Translation ───────────────────────────────────────────────────
SUPPORTED_LANGUAGES=en,es
AUTO_DETECT_LANGUAGE=true

# ── Google Calendar ───────────────────────────────────────────────────────────
# Uncomment and add credentials.json to agent/ to enable scheduling
# GOOGLE_CREDENTIALS_FILE=credentials.json
# GOOGLE_TOKEN_FILE=token.json
GOOGLE_CALENDAR_ID=primary
APPOINTMENT_SLOT_MINUTES=30
AVAILABILITY_LOOKAHEAD_DAYS=7

# ── Business ──────────────────────────────────────────────────────────────────
AGENT_NAME=Alex
BUSINESS_NAME=My Business               # CHANGE_ME
BUSINESS_HOURS_START=9
BUSINESS_HOURS_END=17
BUSINESS_TIMEZONE=America/Chicago       # CHANGE_ME

# ── Extension Routing ─────────────────────────────────────────────────────────
ROUTING_RULES={"sales":"1002","billing":"1002","support":"1003","technical":"1003","operator":"1001","default":"1001"}

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/pbx_assistant.db
