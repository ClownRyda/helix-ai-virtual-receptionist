# ── Asterisk ARI ──────────────────────────────────────────────
# "asterisk" resolves to the Asterisk container via Docker DNS
ASTERISK_HOST=asterisk
ASTERISK_ARI_PORT=8088
ASTERISK_ARI_USER=pbx-agent
ASTERISK_ARI_PASSWORD=CHANGE_ME_ARI_PASSWORD
ASTERISK_APP_NAME=pbx-agent

# ── Agent RTP ─────────────────────────────────────────────────
# 0.0.0.0 so the container accepts RTP from Asterisk container
AGENT_RTP_HOST=0.0.0.0
AGENT_RTP_PORT_START=20000
AGENT_RTP_PORT_END=20100
# Docker service name — Asterisk container uses this to route RTP back to agent
AGENT_RTP_ADVERTISE_HOST=agent

# ── Whisper STT ───────────────────────────────────────────────
# CPU mode for Windows — int8 is fastest on CPU
WHISPER_MODEL=base.en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ── Ollama LLM ────────────────────────────────────────────────
# "ollama" resolves to the Ollama container via Docker DNS
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=qwen3:8b

# ── Piper TTS ─────────────────────────────────────────────────
PIPER_MODEL=en_US-lessac-medium
PIPER_MODEL_PATH=/opt/piper/models

# ── Google Calendar (optional — comment out to skip) ──────────
# GOOGLE_CREDENTIALS_FILE=credentials.json
# GOOGLE_TOKEN_FILE=token.json
GOOGLE_CALENDAR_ID=primary
APPOINTMENT_SLOT_MINUTES=30
AVAILABILITY_LOOKAHEAD_DAYS=7

# ── Business ──────────────────────────────────────────────────
AGENT_NAME=Alex
BUSINESS_NAME=My Business
BUSINESS_HOURS_START=9
BUSINESS_HOURS_END=17
BUSINESS_TIMEZONE=America/Chicago

# ── Routing ───────────────────────────────────────────────────
ROUTING_RULES={"sales":"1002","billing":"1002","support":"1003","technical":"1003","operator":"1001","default":"1001"}

# ── API Server ────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/pbx_assistant.db
