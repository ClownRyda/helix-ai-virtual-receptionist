# Use NVIDIA CUDA base for GPU-accelerated Whisper (faster-whisper / CTranslate2)
FROM nvidia/cuda:12.4.1-cudnn-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1

# Install Python 3.12 + system deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    software-properties-common && \
    add-apt-repository -y ppa:deadsnakes/ppa && \
    apt-get update && apt-get install -y --no-install-recommends \
    python3.12 \
    python3.12-venv \
    python3.12-dev \
    python3-pip \
    ffmpeg \
    wget \
    curl \
    libsndfile1 \
    espeak-ng \
    libespeak-ng-dev \
    && rm -rf /var/lib/apt/lists/*
# Note: libespeak-ng-dev is required by Kokoro's misaki phonemizer for
# out-of-dictionary (OOD) fallback. espeak-ng is also the TTS engine for
# languages without native Kokoro support (DE, RO, HE).

# Set python3.12 as default
RUN update-alternatives --install /usr/bin/python python /usr/bin/python3.12 1 && \
    update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.12 1

# Install pip for Python 3.12
RUN curl -sS https://bootstrap.pypa.io/get-pip.py | python3.12

# Kokoro TTS is installed via pip (see requirements.txt).
# Kokoro model weights are downloaded automatically from Hugging Face on first use
# (cached in ~/.cache/huggingface/hub). No manual binary or model file management needed.

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# Create __init__.py files for submodules
RUN touch stt/__init__.py tts/__init__.py llm/__init__.py calendar/__init__.py routing/__init__.py

# Create data directory for SQLite persistence
RUN mkdir -p /app/data

EXPOSE 8000
EXPOSE 20000-20100/udp

CMD ["python", "main.py"]
