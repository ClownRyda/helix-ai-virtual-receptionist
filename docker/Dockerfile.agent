# Use NVIDIA CUDA base for GPU-accelerated Whisper (faster-whisper / CTranslate2)
FROM nvidia/cuda:12.4.1-cudnn-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1

# Install Python 3.12 + system deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    software-properties-common && \
    add-apt-repository -y ppa:deadsnakes/ppa && \
    apt-get update && apt-get install -y --no-install-recommends \
    python3.12 \
    python3.12-venv \
    python3.12-dev \
    python3-pip \
    ffmpeg \
    wget \
    curl \
    libsndfile1 \
    espeak-ng \
    && rm -rf /var/lib/apt/lists/*

# Set python3.12 as default
RUN update-alternatives --install /usr/bin/python python /usr/bin/python3.12 1 && \
    update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.12 1

# Install pip for Python 3.12
RUN curl -sS https://bootstrap.pypa.io/get-pip.py | python3.12

# Install Piper TTS binary
RUN wget -q https://github.com/rhasspy/piper/releases/latest/download/piper_linux_x86_64.tar.gz \
    -O /tmp/piper.tar.gz && \
    tar -xzf /tmp/piper.tar.gz -C /usr/local/bin/ && \
    rm /tmp/piper.tar.gz

# Create Piper model directory and download default voice
RUN mkdir -p /opt/piper/models && \
    wget -q \
    https://huggingface.co/rhasspy/piper-voices/resolve/main/en/en_US/lessac/medium/en_US-lessac-medium.onnx \
    -O /opt/piper/models/en_US-lessac-medium.onnx && \
    wget -q \
    https://huggingface.co/rhasspy/piper-voices/resolve/main/en/en_US/lessac/medium/en_US-lessac-medium.onnx.json \
    -O /opt/piper/models/en_US-lessac-medium.onnx.json && \
    wget -q \
    https://huggingface.co/rhasspy/piper-voices/resolve/main/es/es_MX/claude/high/es_MX-claude-high.onnx \
    -O /opt/piper/models/es_MX-claude-high.onnx && \
    wget -q \
    https://huggingface.co/rhasspy/piper-voices/resolve/main/es/es_MX/claude/high/es_MX-claude-high.onnx.json \
    -O /opt/piper/models/es_MX-claude-high.onnx.json && \
    wget -q \
    https://huggingface.co/rhasspy/piper-voices/resolve/main/fr/fr_FR/siwis/medium/fr_FR-siwis-medium.onnx \
    -O /opt/piper/models/fr_FR-siwis-medium.onnx && \
    wget -q \
    https://huggingface.co/rhasspy/piper-voices/resolve/main/fr/fr_FR/siwis/medium/fr_FR-siwis-medium.onnx.json \
    -O /opt/piper/models/fr_FR-siwis-medium.onnx.json && \
    wget -q \
    https://huggingface.co/rhasspy/piper-voices/resolve/main/it/it_IT/paola/medium/it_IT-paola-medium.onnx \
    -O /opt/piper/models/it_IT-paola-medium.onnx && \
    wget -q \
    https://huggingface.co/rhasspy/piper-voices/resolve/main/it/it_IT/paola/medium/it_IT-paola-medium.onnx.json \
    -O /opt/piper/models/it_IT-paola-medium.onnx.json && \
    wget -q \
    https://huggingface.co/rhasspy/piper-voices/resolve/main/de/de_DE/thorsten/medium/de_DE-thorsten-medium.onnx \
    -O /opt/piper/models/de_DE-thorsten-medium.onnx && \
    wget -q \
    https://huggingface.co/rhasspy/piper-voices/resolve/main/de/de_DE/thorsten/medium/de_DE-thorsten-medium.onnx.json \
    -O /opt/piper/models/de_DE-thorsten-medium.onnx.json && \
    wget -q \
    https://huggingface.co/rhasspy/piper-voices/resolve/main/ro/ro_RO/mihai/medium/ro_RO-mihai-medium.onnx \
    -O /opt/piper/models/ro_RO-mihai-medium.onnx && \
    wget -q \
    https://huggingface.co/rhasspy/piper-voices/resolve/main/ro/ro_RO/mihai/medium/ro_RO-mihai-medium.onnx.json \
    -O /opt/piper/models/ro_RO-mihai-medium.onnx.json

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# Create __init__.py files for submodules
RUN touch stt/__init__.py tts/__init__.py llm/__init__.py calendar/__init__.py routing/__init__.py

# Create data directory for SQLite persistence
RUN mkdir -p /app/data

EXPOSE 8000
EXPOSE 20000-20100/udp

CMD ["python", "main.py"]
