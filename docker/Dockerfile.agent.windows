# ============================================================
# Agent Dockerfile — Windows / Docker Desktop (CPU)
# No CUDA base — uses standard Python slim image.
# Whisper runs on CPU (int8). Slower but works everywhere.
# Switch to Dockerfile.agent on Linux with an NVIDIA GPU.
# ============================================================
FROM python:3.12-slim

ENV PYTHONUNBUFFERED=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    wget \
    curl \
    libsndfile1 \
    espeak-ng \
    libespeak-ng-dev \
    && rm -rf /var/lib/apt/lists/*
# espeak-ng: required by Kokoro's misaki phonemizer (OOD fallback)
# and as the TTS engine for DE, RO, HE (no Kokoro voice available).

# Kokoro TTS is installed via pip (see requirements.txt).
# Model weights (~300MB) are downloaded automatically from Hugging Face
# on first use and cached in ~/.cache/huggingface/hub.
# No manual binary or model file management needed.

WORKDIR /app

COPY requirements.txt .
# Install CPU-only torch to avoid pulling the full CUDA wheel (~2GB)
RUN pip install --no-cache-dir torch --index-url https://download.pytorch.org/whl/cpu && \
    pip install --no-cache-dir -r requirements.txt

COPY . .

RUN touch stt/__init__.py tts/__init__.py llm/__init__.py \
         calendar/__init__.py routing/__init__.py

RUN mkdir -p /app/data

EXPOSE 8000
EXPOSE 20000-20100/udp

CMD ["python", "main.py"]
