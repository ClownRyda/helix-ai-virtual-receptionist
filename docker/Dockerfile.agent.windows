# ============================================================
# Agent Dockerfile — Windows / Docker Desktop (CPU)
# No CUDA base — uses standard Python slim image.
# Whisper runs on CPU (int8). Slower but works everywhere.
# Switch to Dockerfile.agent on Linux with an NVIDIA GPU.
# ============================================================
FROM python:3.12-slim

ENV PYTHONUNBUFFERED=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    wget \
    curl \
    libsndfile1 \
    && rm -rf /var/lib/apt/lists/*

# Piper TTS binary
RUN wget -q https://github.com/rhasspy/piper/releases/latest/download/piper_linux_x86_64.tar.gz \
    -O /tmp/piper.tar.gz && \
    tar -xzf /tmp/piper.tar.gz -C /usr/local/bin/ && \
    rm /tmp/piper.tar.gz

# Piper voice model
RUN mkdir -p /opt/piper/models && \
    wget -q \
    https://huggingface.co/rhasspy/piper-voices/resolve/main/en/en_US/lessac/medium/en_US-lessac-medium.onnx \
    -O /opt/piper/models/en_US-lessac-medium.onnx && \
    wget -q \
    https://huggingface.co/rhasspy/piper-voices/resolve/main/en/en_US/lessac/medium/en_US-lessac-medium.onnx.json \
    -O /opt/piper/models/en_US-lessac-medium.onnx.json

WORKDIR /app

COPY requirements.txt .
# Install CPU-only torch to avoid pulling the full CUDA wheel (~2GB)
RUN pip install --no-cache-dir torch --index-url https://download.pytorch.org/whl/cpu && \
    pip install --no-cache-dir -r requirements.txt

COPY . .

RUN touch stt/__init__.py tts/__init__.py llm/__init__.py \
         calendar/__init__.py routing/__init__.py

RUN mkdir -p /app/data

EXPOSE 8000
EXPOSE 20000-20100/udp

CMD ["python", "main.py"]
